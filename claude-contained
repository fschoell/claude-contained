#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'EOF'
Usage:
  claude-contained [options] [main_dir] [extra_dir ...] [-- <tool args...>]

Description:
  Runs AI coding assistants inside an Apple Containers sandbox.

Options:
  -t, --tool TOOL    AI tool to run: claude (default), codex, gemini, vibe
  -H PORT[:HOSTPORT] Forward host port to container localhost (can be repeated)
  -p HOST:CONTAINER  Publish container port to host (can be repeated)
  -s, --shell        Start a bash shell instead of the AI tool (for debugging)
  -S, --ssh          Enable SSH agent forwarding (for git push)
  -w, --worktree     Auto-include git worktree's main repository (skip prompt)
  -y, --yolo         Skip all permission prompts (tool-specific flag)
  -N, --contained-node-modules  Use container-specific node_modules (skip prompt)
  -a, --attach [NAME]  Attach to running container (runs tool, or bash with -s)
  -h, --help         Show this help message

Behavior:
  - If no directories are provided, defaults to the current directory.
  - Directories are mounted at their original host paths for full path parity.
  - Additional directories are automatically added via --add-dir (claude, codex only).
  - Tool configs (~/.claude, ~/.codex, ~/.gemini, ~/.vibe), Maven cache (~/.m2), and Vaadin state (~/.vaadin) are bind-mounted.
  - SSH agent forwarding is disabled by default; use --ssh to enable (for git push).
  - Git worktrees are detected; main repository is included for full git access.

Examples:
  claude-contained                     # Run claude in current directory
  claude-contained -t codex .          # Run codex instead
  claude-contained -t gemini .         # Run gemini instead
  claude-contained -t vibe .           # Run vibe instead
  claude-contained . ../other/project  # Mount extra directories
  claude-contained . -- --model sonnet # Pass args to tool
  claude-contained -y -t codex .       # Codex with --yolo
  claude-contained -S .                # Enable SSH agent (for git push)
  claude-contained -s                  # Debug shell in current directory
  claude-contained -p 8080:8080 .      # Expose port 8080
  claude-contained -H 3845 .           # Forward host:3845 to container localhost:3845
  claude-contained -a                  # List and attach to running container
  claude-contained -a myproject        # Attach or create named container
EOF
}

# Sanitize folder name for container naming
# - Extract basename
# - Lowercase
# - Replace non-alphanumeric with dash
# - Collapse multiple dashes
# - Truncate to max 20 chars
# - Handle empty result
sanitize_foldername() {
  local name
  name="$(basename "$1" | tr '[:upper:]' '[:lower:]')"  # lowercase (portable)
  name="$(echo "$name" | sed 's/[^a-z0-9]/-/g')"        # non-alphanumeric → dash
  name="$(echo "$name" | sed 's/-\{1,\}/-/g')"          # collapse dashes
  name="${name#-}"                                       # trim leading dash
  name="${name%-}"                                       # trim trailing dash
  name="$(echo "$name" | cut -c1-20)"                   # truncate (portable)
  [[ -z "$name" ]] && name="root"                       # fallback
  echo "$name"
}

# Get full executable path for a tool (claude is in /opt/claude, others in standard PATH)
get_tool_path() {
  case "$1" in
    claude) echo "/opt/claude/claude" ;;
    *)      echo "$1" ;;  # codex/gemini/vibe are in /usr/local/bin (standard PATH)
  esac
}

# Build command array for attach mode (tool path + flags)
# Sets global attach_cmd array
build_attach_cmd() {
  attach_cmd=("$(get_tool_path "$tool")")
  if [[ $yolo_mode -eq 1 ]]; then
    case "$tool" in
      claude) attach_cmd+=(--dangerously-skip-permissions) ;;
      codex|gemini) attach_cmd+=(--yolo) ;;
      vibe) echo "Warning: vibe does not support yolo mode" >&2 ;;
    esac
  fi
}

# Environment args for exec (PATH not set by entrypoint when using exec)
exec_env_args() {
  printf '%s ' -e "HOME=$HOME" -e "PATH=/opt/claude:$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

# Parse flags (can appear in any order)
shell_mode=0
ssh_mode=0
worktree_mode=0
yolo_mode=0
contained_node_modules=0
attach_mode=0
attach_name=""
custom_container_name=""
tool="claude"
port_maps=()
host_forwards=()
while [[ "${1:-}" == -* ]]; do
  case "${1:-}" in
    -s|--shell)
      shell_mode=1
      shift
      ;;
    -S|--ssh)
      ssh_mode=1
      shift
      ;;
    -w|--worktree)
      worktree_mode=1
      shift
      ;;
    -y|--yolo)
      yolo_mode=1
      shift
      ;;
    -N|--contained-node-modules)
      contained_node_modules=1
      shift
      ;;
    -t|--tool)
      shift
      tool="$1"
      shift
      ;;
    -p)
      shift
      port_maps+=("$1")
      shift
      ;;
    -H)
      shift
      host_forwards+=("$1")
      shift
      ;;
    -a|--attach)
      attach_mode=1
      shift
      # If next arg exists and doesn't start with - and isn't a path, treat as container name
      if [[ -n "${1:-}" && "${1:-}" != -* && "${1:-}" != */* && "${1:-}" != "." ]]; then
        attach_name="$1"
        shift
      fi
      ;;
    *)
      break
      ;;
  esac
done

# Ensure container system is running
if ! container system status &>/dev/null; then
  read -p "Container system is not running. Start it? [Y/n] " answer
  case "${answer:-Y}" in
    [Yy]* ) container system start ;;
    * ) echo "Aborted."; exit 1 ;;
  esac
fi

# Handle attach mode
if [[ $attach_mode -eq 1 ]]; then
  # Get running containers with our prefix
  prefix="claude-contained-"
  containers=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && containers+=("$line")
  done < <(container list --quiet 2>/dev/null | grep "^${prefix}" || true)

  if [[ -z "$attach_name" ]]; then
    # Interactive mode
    if [[ ${#containers[@]} -eq 0 ]]; then
      echo "No running claude-contained containers"
      exit 0
    fi

    echo "Running containers:"
    for i in "${!containers[@]}"; do
      # Display without prefix for cleaner output
      display_name="${containers[$i]#${prefix}}"
      echo "  $((i+1))) ${display_name}"
    done
    echo ""
    read -p "Select container (1-${#containers[@]}, q to quit): " choice

    # Handle quit
    if [[ -z "$choice" || "$choice" == "q" || "$choice" == "Q" ]]; then
      exit 0
    fi

    # Validate selection
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#containers[@]} )); then
      echo "Invalid selection" >&2
      exit 1
    fi

    attach_name="${containers[$((choice-1))]}"
    if [[ $shell_mode -eq 1 ]]; then
      exec container exec -it -u dev $(exec_env_args) "$attach_name" bash
    else
      build_attach_cmd
      exec container exec -it -u dev $(exec_env_args) "$attach_name" "${attach_cmd[@]}"
    fi
  else
    # Direct mode - prepend prefix if not present
    if [[ "$attach_name" != ${prefix}* ]]; then
      attach_name="${prefix}${attach_name}"
    fi
    # Check if container exists
    if [[ ${#containers[@]} -eq 0 ]] || ! printf '%s\n' "${containers[@]}" | grep -qx "$attach_name"; then
      # Container doesn't exist - use as custom name for new container
      raw_name="${attach_name#${prefix}}"
      custom_container_name="${prefix}$(sanitize_foldername "$raw_name")"
      # Fall through to create new container
    else
      if [[ $shell_mode -eq 1 ]]; then
        exec container exec -it -u dev $(exec_env_args) "$attach_name" bash
      else
        build_attach_cmd
        exec container exec -it -u dev $(exec_env_args) "$attach_name" "${attach_cmd[@]}"
      fi
    fi
  fi
fi

if [[ $# -eq 0 ]]; then
  set -- "."
fi

# Split directories (before --) vs tool args (after --)
paths=()
tool_args=()
seen_sep=0
for a in "$@"; do
  if [[ "$a" == "--" ]]; then
    seen_sep=1
    continue
  fi
  if [[ $seen_sep -eq 0 ]]; then
    paths+=("$a")
  else
    tool_args+=("$a")
  fi
done

# If user did: claude-contained -- <claude args...>
if [[ ${#paths[@]} -eq 0 ]]; then
  paths+=(".")
fi

container_arch() {
  local arch
  arch="$(uname -m)"
  # Normalize macOS arm64 to Linux aarch64
  [[ "$arch" == "arm64" ]] && arch="aarch64"
  echo "$arch"
}

resolve_path() {
  if command -v python3 &>/dev/null; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1"
  elif command -v realpath &>/dev/null; then
    realpath "$1"
  elif command -v readlink &>/dev/null && readlink -f / &>/dev/null; then
    readlink -f "$1"
  else
    # Fallback: works for directories
    (cd "$1" 2>/dev/null && pwd) || echo "$1"
  fi
}

# Detect if directory is a git worktree and return main repo path
# Returns empty string if not a worktree
get_worktree_main_repo() {
  local dir="$1"
  local git_file="${dir}/.git"

  # Check if .git is a file (worktree) not a directory (regular repo)
  if [[ -f "$git_file" ]]; then
    # Use git to find the main repository's .git directory
    local common_dir
    common_dir="$(cd "$dir" && git rev-parse --git-common-dir 2>/dev/null)" || return

    # Get the main repo root (parent of .git)
    if [[ -n "$common_dir" && "$common_dir" != ".git" ]]; then
      dirname "$(resolve_path "$common_dir")"
    fi
  fi
}

check_for_updates() {
  (
    local script_path script_dir repo_root local_rev upstream_rev
    script_path="$(resolve_path "$0")"
    script_dir="$(dirname "$script_path")"
    repo_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null)" || return 0
    git -C "$repo_root" fetch --quiet 2>/dev/null || return 0
    local_rev="$(git -C "$repo_root" rev-parse HEAD 2>/dev/null)" || return 0
    upstream_rev="$(git -C "$repo_root" rev-parse '@{u}' 2>/dev/null)" || return 0
    if [[ "$local_rev" != "$upstream_rev" ]]; then
      echo ""
      echo "Update available for claude-contained! Run 'git -C ${repo_root} pull' to update."
    fi
  ) 2>/dev/null || true
}

main_host="$(resolve_path "${paths[0]}")"

# Check if main directory is a git worktree
worktree_main_repo=""
worktree_main_repo="$(get_worktree_main_repo "$main_host")" || true

if [[ -n "$worktree_main_repo" ]]; then
  if [[ $worktree_mode -eq 1 ]]; then
    # Auto-include mode: just inform the user
    echo "Worktree detected: also including main repository ${worktree_main_repo}"
  else
    # Prompt mode: ask the user
    echo "Working directory is a git worktree linked to: ${worktree_main_repo}"
    read -p "Include main repository for full git access? [Y/n] " answer
    case "${answer:-Y}" in
      [Yy]* ) : ;;  # Continue, will be included
      * ) worktree_main_repo="" ;;  # Don't include
    esac
  fi
fi

# Capture host HOME for path parity
HOST_HOME="$HOME"
HOST_CLAUDE_DIR="${HOST_HOME}/.claude"
HOST_CODEX_DIR="${HOST_HOME}/.codex"
HOST_GEMINI_DIR="${HOST_HOME}/.gemini"
HOST_VIBE_DIR="${HOST_HOME}/.vibe"
HOST_M2_DIR="${HOST_HOME}/.m2"
HOST_VAADIN_DIR="${HOST_HOME}/.vaadin"
HOST_GITCONFIG="${HOST_HOME}/.gitconfig"

# Ensure persistent directories exist on host
mkdir -p "${HOST_CLAUDE_DIR}" "${HOST_CODEX_DIR}" "${HOST_GEMINI_DIR}" "${HOST_VIBE_DIR}" "${HOST_M2_DIR}" "${HOST_VAADIN_DIR}"

# Build container args
CLAUDE_MEMORY="${CLAUDE_MEMORY:-8g}"
if [[ -n "$custom_container_name" ]]; then
  container_name="$custom_container_name"
  echo "Creating named container: ${container_name#claude-contained-}"
else
  container_folder="$(sanitize_foldername "$main_host")"
  container_time="$(date +%H%M)"
  container_name="claude-contained-${container_folder}-${container_time}"
fi
container_argv=(
  container run --rm -it
  --memory "${CLAUDE_MEMORY}"
  --name "$container_name"
  -e "HOST_HOME=${HOST_HOME}"
  -e "HOST_UID=$(id -u)"
  -e "HOST_GID=$(id -g)"
  -w "${main_host}"
  --mount "type=bind,src=${HOST_CLAUDE_DIR},dst=${HOST_HOME}/.claude"
  --mount "type=bind,src=${HOST_CODEX_DIR},dst=${HOST_HOME}/.codex"
  --mount "type=bind,src=${HOST_GEMINI_DIR},dst=${HOST_HOME}/.gemini"
  --mount "type=bind,src=${HOST_VIBE_DIR},dst=${HOST_HOME}/.vibe"
  --mount "type=bind,src=${HOST_M2_DIR},dst=${HOST_HOME}/.m2"
  --mount "type=bind,src=${HOST_VAADIN_DIR},dst=${HOST_HOME}/.vaadin"
  --mount "type=bind,src=${main_host},dst=${main_host}"
)

# Mount worktree's main repository if needed
if [[ -n "$worktree_main_repo" ]]; then
  container_argv+=( --mount "type=bind,src=${worktree_main_repo},dst=${worktree_main_repo}" )
fi

# Add port mappings
for pm in "${port_maps[@]+"${port_maps[@]}"}"; do
  container_argv+=( -p "$pm" )
done

# Add host port forwards (container localhost → host)
if [[ ${#host_forwards[@]} -gt 0 ]]; then
  IFS=','; forwards_str="${host_forwards[*]}"; unset IFS
  container_argv+=( -e "HOST_FORWARD_PORTS=${forwards_str}" )
fi

# SSH agent forwarding (opt-in for security)
if [[ $ssh_mode -eq 1 ]]; then
  container_argv+=( --ssh )
fi

# Share ~/.claude.json via symlink to shared directory (can't bind-mount individual files)
# See: https://github.com/apple/containerization/issues/79
# Canonical location is ~/.claude-contained/.claude.json; ~/.claude.json is a symlink to it.
# All containers access the same file via virtiofs, so Claude Code's own locking works.
HOST_CLAUDE_CONTAINED="${HOST_HOME}/.claude-contained"
HOST_CLAUDE_JSON="${HOST_HOME}/.claude.json"
SHARED_CLAUDE_JSON="${HOST_CLAUDE_CONTAINED}/.claude.json"
mkdir -p "${HOST_CLAUDE_CONTAINED}"

# Git config (for commit identity)
# Apple Containers can't bind-mount individual files, so copy to shared directory
if [[ -f "${HOST_GITCONFIG}" ]]; then
  cp "${HOST_GITCONFIG}" "${HOST_CLAUDE_CONTAINED}/.gitconfig"
fi

# Migrate/repair: ensure ~/.claude.json is symlink to shared location
if [[ -f "$HOST_CLAUDE_JSON" && ! -L "$HOST_CLAUDE_JSON" ]]; then
  # Host file is regular file (not symlink) - migrate it to shared location
  # This handles: first run, or host Claude Code replaced symlink via atomic write
  mv "$HOST_CLAUDE_JSON" "$SHARED_CLAUDE_JSON"
  ln -s "$SHARED_CLAUDE_JSON" "$HOST_CLAUDE_JSON"
elif [[ -L "$HOST_CLAUDE_JSON" && ! -e "$SHARED_CLAUDE_JSON" ]]; then
  # Symlink exists but target doesn't - broken symlink, remove it
  rm "$HOST_CLAUDE_JSON"
fi

# Ensure symlink exists (if shared file exists but no symlink yet)
if [[ ! -e "$HOST_CLAUDE_JSON" && -f "$SHARED_CLAUDE_JSON" ]]; then
  ln -s "$SHARED_CLAUDE_JSON" "$HOST_CLAUDE_JSON"
fi

# Mount the shared directory for bidirectional ~/.claude.json access
container_argv+=( --mount "type=bind,src=${HOST_CLAUDE_CONTAINED},dst=${HOST_CLAUDE_CONTAINED}" )

# Build tool-specific command
case "$tool" in
  claude)
    tool_argv=(claude)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--dangerously-skip-permissions)
    ;;
  codex)
    tool_argv=(codex)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--yolo)
    ;;
  gemini)
    tool_argv=(gemini)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--yolo)
    ;;
  vibe)
    tool_argv=(vibe)
    [[ $yolo_mode -eq 1 ]] && echo "Warning: vibe does not support yolo mode (no equivalent flag)" >&2
    ;;
  *)
    echo "Unknown tool: $tool" >&2
    echo "Supported tools: claude, codex, gemini, vibe" >&2
    exit 1
    ;;
esac

# Additional mounts at original host paths
for p in "${paths[@]:1}"; do
  hp="$(resolve_path "$p")"
  container_argv+=( --mount "type=bind,src=${hp},dst=${hp}" )
  # Only claude and codex support --add-dir
  [[ "$tool" == "claude" || "$tool" == "codex" ]] && tool_argv+=( --add-dir "${hp}" )
done

# Platform-specific node_modules overlay
if [[ "$(uname)" != "Linux" ]]; then
  # Container is Linux; host is not — node_modules may need platform-specific binaries
  nm_platform="linux-$(container_arch)"
  nm_check_dirs=("$main_host")
  for p in "${paths[@]:1}"; do
    nm_check_dirs+=("$(resolve_path "$p")")
  done

  nm_overlay_dirs=()
  for nm_dir in "${nm_check_dirs[@]}"; do
    [[ -f "${nm_dir}/package.json" ]] && nm_overlay_dirs+=("$nm_dir")
  done

  if [[ ${#nm_overlay_dirs[@]} -gt 0 ]]; then
    do_overlay=$contained_node_modules
    if [[ $do_overlay -eq 0 ]]; then
      read -p "Node.js project detected. Use container-specific node_modules? [Y/n] " answer
      [[ "${answer:-Y}" =~ ^[Yy] ]] && do_overlay=1
    fi

    if [[ $do_overlay -eq 1 ]]; then
      for nm_dir in "${nm_overlay_dirs[@]}"; do
        nm_target="${nm_dir}/node_modules-${nm_platform}"
        mkdir -p "${nm_target}"
        container_argv+=( --mount "type=bind,src=${nm_target},dst=${nm_dir}/node_modules" )
        if [[ -z "$(ls -A "${nm_target}" 2>/dev/null)" ]]; then
          echo "Created ${nm_target}" >&2
          echo "  Run 'npm install' (or your package manager) inside the container." >&2
        fi
      done
    fi
  fi
fi

# Add worktree main repo to agent's folders
if [[ -n "$worktree_main_repo" ]]; then
  [[ "$tool" == "claude" || "$tool" == "codex" ]] && tool_argv+=( --add-dir "${worktree_main_repo}" )
fi

# Append user's tool args
if [[ ${#tool_args[@]} -gt 0 ]]; then
  tool_argv+=( "${tool_args[@]}" )
fi

# Run container
if [[ $shell_mode -eq 1 ]]; then
  "${container_argv[@]}" claude-contained:latest bash && container_exit=0 || container_exit=$?
else
  "${container_argv[@]}" claude-contained:latest "${tool_argv[@]}" && container_exit=0 || container_exit=$?
fi

check_for_updates

exit "$container_exit"
