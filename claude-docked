#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'EOF'
Usage:
  claude-docked [options] [main_dir] [extra_dir ...] [-- <tool args...>]

Description:
  Runs AI coding assistants inside a Docker container.

Options:
  -t, --tool TOOL    AI tool to run: claude (default), codex, copilot, gemini, vibe
  -R, --rebuild[=MODE]  Rebuild image and exit: tools (default) or full
  -H PORT[:HOSTPORT] Forward host port to container localhost (can be repeated)
  -p HOST:CONTAINER  Publish container port to host (can be repeated)
  -s, --shell        Start a bash shell instead of the AI tool (for debugging)
  -S, --ssh          Enable SSH agent forwarding (for git push)
  -w, --worktree     Auto-include git worktree's main repository (skip prompt)
  -W, --lock-worktrees  Auto-lock hidden linked worktrees (skip prompt)
  -y, --yolo         Skip all permission prompts (tool-specific flag)
  -N, --contained-node-modules  Use container-specific node_modules (skip prompt)
  --share-skills=DIR  Mount shared skill folders from DIR (opt-in)
  --readonly-extras  Mount all extra dirs read-only (suffix overrides per-path)
  -a, --attach [NAME]  Attach to running container (runs tool, or bash with -s)
  -h, --help         Show this help message

Behavior:
  - If no directories are provided, defaults to the current directory.
  - Directories are mounted at their original host paths for full path parity.
  - Additional directories are automatically added via --add-dir (claude, codex only).
  - Append :ro to an extra dir to mount it read-only (or :rw to force read-write).
    The working directory cannot be read-only.
  - Tool configs (~/.claude, ~/.codex, ~/.copilot, ~/.gemini, ~/.vibe), Maven cache (~/.m2), and Vaadin state (~/.vaadin) are bind-mounted.
  - --share-skills=DIR mounts DIR as each tool's skills directory.
    For Codex, ~/.codex/skills/.system is mounted back over DIR/.system
    so built-in skills remain visible while new installs write to DIR.
  - SSH agent forwarding is disabled by default; use --ssh to enable (for git push).
  - Git worktrees are detected; main repository's .git directory is mounted for full git access.
  - Linked worktrees hidden from the container can be auto-locked while the container runs.

Examples:
  claude-docked                      # Run claude in current directory
  claude-docked -t codex .           # Run codex instead
  claude-docked -t copilot .         # Run copilot instead
  claude-docked -t gemini .          # Run gemini instead
  claude-docked -t vibe .            # Run vibe instead
  claude-docked . ../other/project   # Mount extra directories
  claude-docked . ../lib:ro          # Mount ../lib read-only
  claude-docked --readonly-extras . ../a ../b  # All extras read-only
  claude-docked . -- --model sonnet  # Pass args to tool
  claude-docked -y -t codex .        # Codex with --yolo
  claude-docked -S .                 # Enable SSH agent (for git push)
  claude-docked -s                   # Debug shell in current directory
  claude-docked --rebuild            # Refresh AI tools, then exit
  claude-docked --rebuild=full      # Full fresh rebuild, then exit
  claude-docked -p 8080:8080 .       # Expose port 8080
  claude-docked -H 3845 .            # Forward host:3845 to container localhost:3845
  claude-docked --share-skills=/Users/me/Projects/skills .
  claude-docked -a                   # List and attach to running container
  claude-docked -a myproject         # Attach or create named container

Build the image:
  docker build -t claude-contained .
EOF
}

# Sanitize folder name for container naming
# - Extract basename
# - Lowercase
# - Replace non-alphanumeric with dash
# - Collapse multiple dashes
# - Truncate to max 20 chars
# - Handle empty result
sanitize_foldername() {
  local name
  name="$(basename "$1" | tr '[:upper:]' '[:lower:]')"  # lowercase (portable)
  name="$(echo "$name" | sed 's/[^a-z0-9]/-/g')"        # non-alphanumeric → dash
  name="$(echo "$name" | sed 's/-\{1,\}/-/g')"          # collapse dashes
  name="${name#-}"                                       # trim leading dash
  name="${name%-}"                                       # trim trailing dash
  name="$(echo "$name" | cut -c1-20)"                   # truncate (portable)
  [[ -z "$name" ]] && name="root"                       # fallback
  echo "$name"
}

# Get full executable path for a tool (claude is in /opt/claude, others in standard PATH)
get_tool_path() {
  case "$1" in
    claude) echo "/opt/claude/claude" ;;
    *)      echo "$1" ;;  # codex/gemini/vibe are in /usr/local/bin (standard PATH)
  esac
}

# Build command array for attach mode (tool path + flags)
# Sets global attach_cmd array
build_attach_cmd() {
  attach_cmd=("$(get_tool_path "$tool")")
  if [[ $yolo_mode -eq 1 ]]; then
    case "$tool" in
      claude) attach_cmd+=(--dangerously-skip-permissions) ;;
      codex|copilot|gemini) attach_cmd+=(--yolo) ;;
      vibe) echo "Warning: vibe does not support yolo mode" >&2 ;;
    esac
  fi
}

# Environment args for exec (PATH not set by entrypoint when using exec)
exec_env_args() {
  printf '%s ' -e "HOME=$HOME" -e "JAVA_HOME=/opt/jbr" -e "PATH=/opt/claude:/home/dev/.sdkman/candidates/maven/current/bin:/home/dev/.sdkman/candidates/jbang/current/bin:/opt/jbr/bin:$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
}

resolve_path() {
  if command -v python3 &>/dev/null; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1"
  elif command -v realpath &>/dev/null; then
    realpath "$1"
  elif command -v readlink &>/dev/null && readlink -f / &>/dev/null; then
    readlink -f "$1"
  else
    # Fallback: works for directories
    (cd "$1" 2>/dev/null && pwd) || echo "$1"
  fi
}

container_arch() {
  local arch
  arch="$(uname -m)"
  # Normalize macOS arm64 to Linux aarch64
  [[ "$arch" == "arm64" ]] && arch="aarch64"
  echo "$arch"
}

dir_is_empty() {
  local entry
  for entry in "$1"/* "$1"/.[!.]* "$1"/..?*; do
    [[ -e "$entry" ]] && return 1
  done
  return 0
}

# Detect host's IANA timezone (e.g. "Europe/Helsinki") so the container clock
# matches the host. Works on macOS (/var/db/timezone/zoneinfo/...) and Linux
# (/usr/share/zoneinfo/...). Falls back to $TZ if set, then empty.
host_timezone() {
  if [[ -n "${TZ:-}" ]]; then
    echo "$TZ"
    return
  fi
  local link
  link="$(readlink /etc/localtime 2>/dev/null)" || return 0
  [[ "$link" == */zoneinfo/* ]] && echo "${link#*/zoneinfo/}"
}

find_build_context() {
  local script_path script_dir repo_root
  script_path="$(resolve_path "$0")"
  script_dir="$(dirname "$script_path")"
  if [[ -f "${script_dir}/Dockerfile" ]]; then
    echo "$script_dir"
    return 0
  fi
  repo_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null)" || true
  if [[ -n "$repo_root" && -f "${repo_root}/Dockerfile" ]]; then
    echo "$repo_root"
    return 0
  fi
  return 1
}

run_rebuild() {
  local mode="$1"
  local build_context refresh_token

  build_context="$(find_build_context)" || {
    echo "Rebuild requires a repo-adjacent install with Dockerfile access." >&2
    echo "Place claude-docked in this repo checkout (or symlink to it) and retry." >&2
    exit 1
  }

  case "$mode" in
    tools)
      refresh_token="$(date -u +%Y%m%d%H%M%S)"
      echo "Rebuilding claude-contained image (AI tools refresh)..." >&2
      if docker build --build-arg "AI_TOOLS_CACHE_BUST=${refresh_token}" -t claude-contained:latest "$build_context"; then
        return 0
      fi
      echo "AI tools refresh failed. Retrying with full rebuild..." >&2
      run_rebuild full
      return
      ;;
    full)
      echo "Rebuilding claude-contained image (full fresh rebuild)..." >&2
      docker build --pull --no-cache -t claude-contained:latest "$build_context"
      ;;
    *)
      echo "Unknown rebuild mode: $mode" >&2
      echo "Supported rebuild modes: tools, full" >&2
      exit 1
      ;;
  esac
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

# Parse flags (can appear in any order)
shell_mode=0
ssh_mode=0
worktree_mode=0
lock_worktrees=0
yolo_mode=0
contained_node_modules=0
attach_mode=0
attach_name=""
custom_container_name=""
rebuild_mode="none"
tool="claude"
ro_default=0
share_skills_dir=""
port_maps=()
host_forwards=()
while [[ "${1:-}" == -* ]]; do
  case "${1:-}" in
    -h|--help)
      show_help
      exit 0
      ;;
    --readonly-extras)
      ro_default=1
      shift
      ;;
    --share-skills)
      echo "error: --share-skills requires --share-skills=DIR" >&2
      exit 2
      ;;
    --share-skills=*)
      share_skills_dir="${1#*=}"
      if [[ -z "$share_skills_dir" ]]; then
        echo "error: --share-skills requires a non-empty directory" >&2
        exit 2
      fi
      shift
      ;;
    --rebuild)
      rebuild_mode="tools"
      shift
      ;;
    --rebuild=*)
      rebuild_mode="${1#*=}"
      shift
      ;;
    -R)
      if [[ "${2:-}" == "tools" || "${2:-}" == "full" ]]; then
        rebuild_mode="$2"
        shift 2
      else
        rebuild_mode="tools"
        shift
      fi
      ;;
    -s|--shell)
      shell_mode=1
      shift
      ;;
    -S|--ssh)
      ssh_mode=1
      shift
      ;;
    -w|--worktree)
      worktree_mode=1
      shift
      ;;
    -W|--lock-worktrees)
      lock_worktrees=1
      shift
      ;;
    -y|--yolo)
      yolo_mode=1
      shift
      ;;
    -N|--contained-node-modules)
      contained_node_modules=1
      shift
      ;;
    -t|--tool)
      shift
      tool="$1"
      shift
      ;;
    -p)
      shift
      port_maps+=("$1")
      shift
      ;;
    -H)
      shift
      host_forwards+=("$1")
      shift
      ;;
    -a|--attach)
      attach_mode=1
      shift
      # If next arg exists and doesn't start with - and isn't a path, treat as container name
      if [[ -n "${1:-}" && "${1:-}" != -* && "${1:-}" != */* && "${1:-}" != "." ]]; then
        attach_name="$1"
        shift
      fi
      ;;
    *)
      break
      ;;
  esac
done

if [[ -n "$share_skills_dir" ]]; then
  if [[ ! -d "$share_skills_dir" ]]; then
    echo "error: --share-skills directory does not exist: $share_skills_dir" >&2
    exit 2
  fi
  share_skills_dir="$(resolve_path "$share_skills_dir")"
fi

# Ensure Docker is running (skipped when sourced for tests)
if [[ -z "${CLAUDE_CONTAINED_LIB_ONLY:-}" ]] && ! docker info &>/dev/null; then
  read -p "Docker is not running. Start Docker Desktop? [Y/n] " answer
  case "${answer:-Y}" in
    [Yy]* )
      open -a Docker
      echo "Waiting for Docker to start..."
      while ! docker info &>/dev/null; do sleep 1; done
      ;;
    * ) echo "Aborted."; exit 1 ;;
  esac
fi

# Handle rebuild mode (rebuild and exit)
if [[ "$rebuild_mode" != "none" ]]; then
  run_rebuild "$rebuild_mode"
  exit 0
fi

# Handle attach mode
if [[ $attach_mode -eq 1 ]]; then
  # Get running containers with our prefix
  prefix="aic-"
  containers=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && containers+=("$line")
  done < <(docker ps --format '{{.Names}}' --filter "name=^${prefix}" 2>/dev/null || true)

  if [[ -z "$attach_name" ]]; then
    # Interactive mode
    if [[ ${#containers[@]} -eq 0 ]]; then
      echo "No running aic containers"
      exit 0
    fi

    echo "Running containers:"
    for i in "${!containers[@]}"; do
      # Display without prefix for cleaner output
      display_name="${containers[$i]#${prefix}}"
      echo "  $((i+1))) ${display_name}"
    done
    echo ""
    read -p "Select container (1-${#containers[@]}, q to quit): " choice

    # Handle quit
    if [[ -z "$choice" || "$choice" == "q" || "$choice" == "Q" ]]; then
      exit 0
    fi

    # Validate selection
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#containers[@]} )); then
      echo "Invalid selection" >&2
      exit 1
    fi

    attach_name="${containers[$((choice-1))]}"
    if [[ $shell_mode -eq 1 ]]; then
      exec docker exec -it -u dev $(exec_env_args) "$attach_name" bash
    else
      build_attach_cmd
      exec docker exec -it -u dev $(exec_env_args) "$attach_name" "${attach_cmd[@]}"
    fi
  else
    # Direct mode - prepend prefix if not present
    if [[ "$attach_name" != ${prefix}* ]]; then
      attach_name="${prefix}${attach_name}"
    fi
    # Check if container exists
    if [[ ${#containers[@]} -eq 0 ]] || ! printf '%s\n' "${containers[@]}" | grep -qx "$attach_name"; then
      # Container doesn't exist - use as custom name for new container
      raw_name="${attach_name#${prefix}}"
      custom_container_name="${prefix}$(sanitize_foldername "$raw_name")"
      # Fall through to create new container
    else
      if [[ $shell_mode -eq 1 ]]; then
        exec docker exec -it -u dev $(exec_env_args) "$attach_name" bash
      else
        build_attach_cmd
        exec docker exec -it -u dev $(exec_env_args) "$attach_name" "${attach_cmd[@]}"
      fi
    fi
  fi
fi

if [[ $# -eq 0 ]]; then
  set -- "."
fi

# Split directories (before --) vs tool args (after --)
paths=()
tool_args=()
seen_sep=0
for a in "$@"; do
  if [[ "$a" == "--" ]]; then
    seen_sep=1
    continue
  fi
  if [[ $seen_sep -eq 0 ]]; then
    paths+=("$a")
  else
    tool_args+=("$a")
  fi
done

# If user did: claude-docked -- <claude args...>
if [[ ${#paths[@]} -eq 0 ]]; then
  paths+=(".")
fi

# Strip :ro / :rw suffixes; build parallel path_modes[] (rw|ro per index).
# Working dir (index 0) cannot be ro. --readonly-extras sets the default for
# unsuffixed extras; an explicit suffix always wins.
path_modes=()
for i in "${!paths[@]}"; do
  p="${paths[$i]}"
  mode=""
  if   [[ "$p" == *:ro ]]; then p="${p%:ro}"; mode="ro"
  elif [[ "$p" == *:rw ]]; then p="${p%:rw}"; mode="rw"
  fi
  if [[ $i -eq 0 ]]; then
    if [[ "$mode" == "ro" ]]; then
      echo "error: working directory cannot be read-only" >&2
      exit 2
    fi
    mode="rw"
  elif [[ -z "$mode" ]]; then
    [[ $ro_default -eq 1 ]] && mode="ro" || mode="rw"
  fi
  paths[$i]="$p"
  path_modes+=("$mode")
done

# Detect if directory is a git worktree and return main repo path
# Returns empty string if not a worktree
get_worktree_main_repo() {
  local dir="$1"
  local git_file="${dir}/.git"

  # Check if .git is a file (worktree) not a directory (regular repo)
  if [[ -f "$git_file" ]]; then
    # Use git to find the main repository's .git directory
    local common_dir
    common_dir="$(cd "$dir" && git rev-parse --git-common-dir 2>/dev/null)" || return

    # Get the main repo root (parent of .git)
    if [[ -n "$common_dir" && "$common_dir" != ".git" ]]; then
      dirname "$(resolve_path "$common_dir")"
    fi
  fi
}

get_main_worktree_repo_root() {
  local dir="$1"
  local repo_root common_dir common_abs main_git_abs

  repo_root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || return
  [[ -d "${repo_root}/.git" ]] || return

  common_dir="$(git -C "$repo_root" rev-parse --git-common-dir 2>/dev/null)" || return
  common_abs="$(cd "$repo_root" && resolve_path "$common_dir")"
  main_git_abs="$(resolve_path "${repo_root}/.git")"

  [[ "$common_abs" == "$main_git_abs" ]] && echo "$repo_root"
}

path_is_at_or_under() {
  local path="${1%/}"
  local parent="${2%/}"

  [[ "$path" == "$parent" || "$path" == "$parent"/* ]]
}

path_visible_in_container() {
  local path="$1"
  local mounted

  for mounted in "${mounted_roots[@]+"${mounted_roots[@]}"}"; do
    if path_is_at_or_under "$path" "$mounted"; then
      return 0
    fi
  done
  return 1
}

AUTO_LOCK_PREFIX="cc-autolocked-by:"
# A held mutex lives only a fraction of a second; anything older than this was
# left by a launcher that died without releasing it and may be reclaimed.
WORKTREE_LOCK_MUTEX_STALE_SECS=30
WORKTREE_CLEANUP_DONE=0
auto_worktree_lock_repo=""
auto_locked_worktrees=()

get_worktree_lock_file() {
  local wt_path="$1"
  local git_dir

  git_dir="$(git -C "$wt_path" rev-parse --git-dir 2>/dev/null)" || return 1
  git_dir="$(cd "$wt_path" && resolve_path "$git_dir")"
  echo "${git_dir}/locked"
}

# Decide whether a mutex directory we failed to create was abandoned by a dead
# launcher. Without this, a single crash/kill while the mutex was briefly held
# would block every future run on the repo, silently disabling auto-locking.
mutex_holder_is_stale() {
  local lock_dir="$1"
  local owner_file="${lock_dir}/owner"
  local holder_pid="" holder_ts="" now age

  # A live holder writes its owner file within microseconds of creating the
  # directory; a persistently missing one means the holder died mid-acquire.
  [[ -f "$owner_file" ]] || return 0

  read -r holder_pid holder_ts < "$owner_file" 2>/dev/null || true

  # Holder process is gone -> stale.
  if [[ -n "$holder_pid" ]] && ! kill -0 "$holder_pid" 2>/dev/null; then
    return 0
  fi

  # Age fallback guards against PID reuse and platforms with unreliable kill -0.
  now="$(date +%s 2>/dev/null || echo 0)"
  if [[ -n "$holder_ts" && "$holder_ts" -gt 0 && "$now" -gt "$holder_ts" ]]; then
    age=$((now - holder_ts))
    [[ $age -ge $WORKTREE_LOCK_MUTEX_STALE_SECS ]] && return 0
  fi

  return 1
}

with_worktree_lock_mutex() {
  local repo_root="$1"
  local lock_dir="${repo_root}/.git/claude-contained-worktree-locks.lock"
  local waited=0

  while ! mkdir "$lock_dir" 2>/dev/null; do
    # After a short grace period, reclaim the lock if its holder is gone.
    if [[ $waited -ge 5 ]] && mutex_holder_is_stale "$lock_dir"; then
      echo "Note: reclaiming stale worktree auto-lock mutex from a defunct launcher" >&2
      rm -f "${lock_dir}/owner" 2>/dev/null || true
      rmdir "$lock_dir" 2>/dev/null || true
      waited=0
      continue
    fi
    if [[ $waited -ge 50 ]]; then
      echo "Warning: timed out waiting for worktree auto-lock mutex" >&2
      return 1
    fi
    sleep 0.1
    waited=$((waited + 1))
  done

  # Record holder identity + time so a later run can detect a stale hold.
  printf '%s %s\n' "$$" "$(date +%s 2>/dev/null || echo 0)" > "${lock_dir}/owner" 2>/dev/null || true
  WORKTREE_LOCK_MUTEX_DIR="$lock_dir"
}

release_worktree_lock_mutex() {
  if [[ -n "${WORKTREE_LOCK_MUTEX_DIR:-}" ]]; then
    rm -f "${WORKTREE_LOCK_MUTEX_DIR}/owner" 2>/dev/null || true
    rmdir "$WORKTREE_LOCK_MUTEX_DIR" 2>/dev/null || true
    WORKTREE_LOCK_MUTEX_DIR=""
  fi
}

reason_has_auto_owner() {
  local reason="$1"
  local owner="$2"
  local owner_part existing

  [[ "$reason" == "$AUTO_LOCK_PREFIX"* ]] || return 1
  owner_part="${reason#${AUTO_LOCK_PREFIX}}"
  for existing in $owner_part; do
    [[ "$existing" == "$owner" ]] && return 0
  done
  return 1
}

write_auto_lock_reason() {
  local lock_file="$1"
  shift
  local reason="$AUTO_LOCK_PREFIX"
  local owner

  for owner in "$@"; do
    reason="${reason} ${owner}"
  done
  printf '%s\n' "$reason" > "$lock_file"
}

append_auto_lock_owner() {
  local lock_file="$1"
  local owner="$2"
  local reason owner_part existing
  local owners=()

  reason="$(cat "$lock_file" 2>/dev/null || true)"
  [[ "$reason" == "$AUTO_LOCK_PREFIX"* ]] || return 1
  reason_has_auto_owner "$reason" "$owner" && return 0

  owner_part="${reason#${AUTO_LOCK_PREFIX}}"
  for existing in $owner_part; do
    owners+=("$existing")
  done
  owners+=("$owner")
  write_auto_lock_reason "$lock_file" "${owners[@]}"
}

record_auto_locked_worktree() {
  local wt_path="$1"
  local existing

  for existing in "${auto_locked_worktrees[@]+"${auto_locked_worktrees[@]}"}"; do
    [[ "$existing" == "$wt_path" ]] && return 0
  done
  auto_locked_worktrees+=("$wt_path")
}

add_auto_worktree_lock_owner() {
  local repo_root="$1"
  local wt_path="$2"
  local owner="$3"
  local lock_file reason

  lock_file="$(get_worktree_lock_file "$wt_path")" || return 1
  if [[ -f "$lock_file" ]]; then
    append_auto_lock_owner "$lock_file" "$owner" || return 1
  else
    if ! git -C "$repo_root" worktree lock --reason "${AUTO_LOCK_PREFIX} ${owner}" "$wt_path" 2>/dev/null; then
      reason="$(cat "$lock_file" 2>/dev/null || true)"
      [[ "$reason" == "$AUTO_LOCK_PREFIX"* ]] || return 1
      append_auto_lock_owner "$lock_file" "$owner" || return 1
    fi
  fi

  record_auto_locked_worktree "$wt_path"
}

remove_auto_worktree_lock_owner() {
  local repo_root="$1"
  local wt_path="$2"
  local owner="$3"
  local lock_file reason owner_part existing
  local owners=()
  local found=0

  [[ -d "$wt_path" ]] || return 0
  lock_file="$(get_worktree_lock_file "$wt_path")" || return 0
  [[ -f "$lock_file" ]] || return 0

  reason="$(cat "$lock_file" 2>/dev/null || true)"
  [[ "$reason" == "$AUTO_LOCK_PREFIX"* ]] || return 0

  owner_part="${reason#${AUTO_LOCK_PREFIX}}"
  for existing in $owner_part; do
    if [[ "$existing" == "$owner" ]]; then
      found=1
    else
      owners+=("$existing")
    fi
  done
  [[ $found -eq 1 ]] || return 0

  if [[ ${#owners[@]} -eq 0 ]]; then
    git -C "$repo_root" worktree unlock "$wt_path" 2>/dev/null || rm -f "$lock_file"
  else
    write_auto_lock_reason "$lock_file" "${owners[@]}"
  fi
}

cleanup_auto_worktree_locks() {
  local wt_path
  local mutex_held=0

  [[ ${WORKTREE_CLEANUP_DONE:-0} -eq 1 ]] && return 0
  WORKTREE_CLEANUP_DONE=1

  [[ -n "$auto_worktree_lock_repo" && ${#auto_locked_worktrees[@]} -gt 0 ]] || return 0

  if [[ -n "${WORKTREE_LOCK_MUTEX_DIR:-}" ]]; then
    mutex_held=1
  elif with_worktree_lock_mutex "$auto_worktree_lock_repo"; then
    mutex_held=1
  fi

  # Only edit the owner list while holding the mutex: a racing cleanup could
  # otherwise drop a still-live owner and unlock a worktree another container is
  # using. If the mutex is unavailable, leave the locks in place (release with
  # `git worktree unlock`); erring toward over-locking never destroys data.
  if [[ $mutex_held -eq 1 ]]; then
    for wt_path in "${auto_locked_worktrees[@]}"; do
      remove_auto_worktree_lock_owner "$auto_worktree_lock_repo" "$wt_path" "$container_name"
    done
    release_worktree_lock_mutex
  else
    echo "Warning: could not acquire worktree auto-lock mutex during cleanup;" >&2
    echo "         leaving auto-locks in place (release with 'git -C \"${auto_worktree_lock_repo}\" worktree unlock <path>')." >&2
  fi
  return 0
}

maybe_offer_worktree_locks() {
  local repo_root="$1"
  local container_name="$2"
  local line wt_path locked locked_reason prunable
  local hidden_worktrees=()

  [[ -n "$repo_root" ]] || return 0
  path_visible_in_container "${repo_root}/.git" || return 0

  wt_path=""
  locked=0
  locked_reason=""
  prunable=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$line" ]]; then
      if [[ -n "$wt_path" && "$wt_path" != "$repo_root" && $prunable -eq 0 && -d "$wt_path" ]]; then
        if ! path_visible_in_container "$wt_path"; then
          if [[ $locked -eq 0 || "$locked_reason" == "$AUTO_LOCK_PREFIX"* ]]; then
            hidden_worktrees+=("$wt_path")
          fi
        fi
      fi
      wt_path=""
      locked=0
      locked_reason=""
      prunable=0
      continue
    fi

    case "$line" in
      worktree\ *) wt_path="${line#worktree }" ;;
      locked*) locked=1; locked_reason="${line#locked}"; locked_reason="${locked_reason# }" ;;
      prunable*) prunable=1 ;;
    esac
  done < <(git -C "$repo_root" worktree list --porcelain 2>/dev/null || true)

  if [[ -n "$wt_path" && "$wt_path" != "$repo_root" && $prunable -eq 0 && -d "$wt_path" ]]; then
    if ! path_visible_in_container "$wt_path"; then
      if [[ $locked -eq 0 || "$locked_reason" == "$AUTO_LOCK_PREFIX"* ]]; then
        hidden_worktrees+=("$wt_path")
      fi
    fi
  fi

  [[ ${#hidden_worktrees[@]} -gt 0 ]] || return 0

  echo "${#hidden_worktrees[@]} linked worktree(s) under ${repo_root} hidden from container (prune risk)."
  if [[ ${lock_worktrees:-0} -eq 1 ]]; then
    answer="Y"
  else
    read -p "Auto-lock them while this container runs? [Y/n] " answer
  fi
  case "${answer:-Y}" in
    [Yy]* )
      auto_worktree_lock_repo="$repo_root"
      # Fail safe: if the mutex is unavailable, still apply the locks rather
      # than launch the container with the worktrees unprotected. The mutex only
      # serializes the owner-list bookkeeping; a lone racing append at worst
      # leaks a lock (over-protection), never a removal.
      if ! with_worktree_lock_mutex "$repo_root"; then
        echo "Warning: proceeding to auto-lock without the serialization mutex;" >&2
        echo "         a concurrent launcher on this repo could race on lock bookkeeping." >&2
      fi
      for wt_path in "${hidden_worktrees[@]}"; do
        if ! add_auto_worktree_lock_owner "$repo_root" "$wt_path" "$container_name"; then
          echo "Warning: could not auto-lock ${wt_path}; leaving it unchanged" >&2
        fi
      done
      release_worktree_lock_mutex
      echo "Auto-locked ${#auto_locked_worktrees[@]} worktree(s)."
      ;;
  esac
}

check_for_updates() {
  (
    local script_path script_dir repo_root local_rev upstream_rev
    script_path="$(resolve_path "$0")"
    script_dir="$(dirname "$script_path")"
    repo_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null)" || return 0
    git -C "$repo_root" fetch --quiet 2>/dev/null || return 0
    local_rev="$(git -C "$repo_root" rev-parse HEAD 2>/dev/null)" || return 0
    upstream_rev="$(git -C "$repo_root" rev-parse '@{u}' 2>/dev/null)" || return 0
    if [[ "$local_rev" != "$upstream_rev" ]]; then
      echo ""
      echo "Update available for claude-contained! Run 'git -C ${repo_root} pull' to update."
    fi
  ) 2>/dev/null || true
}

# Test hook: when sourced with CLAUDE_CONTAINED_LIB_ONLY=1, stop here so the
# helper functions above can be unit-tested without launching a container.
if [[ -n "${CLAUDE_CONTAINED_LIB_ONLY:-}" ]]; then
  return 0
fi

main_host="$(resolve_path "${paths[0]}")"

mounted_roots=("$main_host")
for p in "${paths[@]:1}"; do
  mounted_roots+=("$(resolve_path "$p")")
done

# Check if main directory is a git worktree
worktree_main_repo=""
worktree_main_repo="$(get_worktree_main_repo "$main_host")" || true

if [[ -n "$worktree_main_repo" ]]; then
  if [[ $worktree_mode -eq 1 ]]; then
    # Auto-include mode: just inform the user
    echo "Worktree detected: mounting ${worktree_main_repo}/.git for full git access"
  else
    # Prompt mode: ask the user
    echo "Working directory is a git worktree linked to: ${worktree_main_repo}"
    read -p "Mount main repository's .git for full git access? [Y/n] " answer
    case "${answer:-Y}" in
      [Yy]* ) : ;;  # Continue, will be included
      * ) worktree_main_repo="" ;;  # Don't include
    esac
  fi
fi
if [[ -n "$worktree_main_repo" ]]; then
  mounted_roots+=("${worktree_main_repo}/.git")
fi

# Capture host HOME for path parity
HOST_HOME="$HOME"
HOST_CLAUDE_DIR="${HOST_HOME}/.claude"
HOST_CODEX_DIR="${HOST_HOME}/.codex"
HOST_GEMINI_DIR="${HOST_HOME}/.gemini"
HOST_COPILOT_DIR="${HOST_HOME}/.copilot"
HOST_VIBE_DIR="${HOST_HOME}/.vibe"
HOST_M2_DIR="${HOST_HOME}/.m2"
HOST_VAADIN_DIR="${HOST_HOME}/.vaadin"
HOST_GITCONFIG="${HOST_HOME}/.gitconfig"

# Ensure persistent directories exist on host
mkdir -p "${HOST_CLAUDE_DIR}" "${HOST_CODEX_DIR}" "${HOST_COPILOT_DIR}" "${HOST_GEMINI_DIR}" "${HOST_VIBE_DIR}" "${HOST_M2_DIR}" "${HOST_VAADIN_DIR}"

# Build container args
CLAUDE_MEMORY="${CLAUDE_MEMORY:-8g}"
if [[ -n "$custom_container_name" ]]; then
  container_name="$custom_container_name"
  echo "Creating named container: ${container_name#aic-}"
else
  container_folder="$(sanitize_foldername "$main_host")"
  container_time="$(date +%H%M)"
  container_name="aic-${container_folder}-${container_time}"
fi
# Deduplicate: append -2, -3, ... if a container with the same name already exists
base_container_name="$container_name"
suffix=2
while docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$container_name"; do
  container_name="${base_container_name}-${suffix}"
  ((suffix++))
done
worktree_lock_repo="$worktree_main_repo"
if [[ -z "$worktree_lock_repo" ]]; then
  worktree_lock_repo="$(get_main_worktree_repo_root "$main_host")" || true
fi
trap cleanup_auto_worktree_locks EXIT
# Route common termination signals through `exit` so the EXIT handler (which
# releases the mutex and removes this container's lock owners) always runs.
# Bash defers a trapped signal until the foreground `docker run` returns, so
# cleanup never fires while the container could still prune worktrees.
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP
maybe_offer_worktree_locks "$worktree_lock_repo" "$container_name"
HOST_TZ="$(host_timezone)"
container_argv=(
  docker run --rm -it
  --memory "${CLAUDE_MEMORY}"
  --name "$container_name"
  -e "HOST_HOME=${HOST_HOME}"
  -e "HOST_UID=$(id -u)"
  -e "HOST_GID=$(id -g)"
  -w "${main_host}"
  ${HOST_TZ:+-e "TZ=${HOST_TZ}"}
  ${AI_GH_TOKEN:+-e "GH_TOKEN=${AI_GH_TOKEN}"}
  --mount "type=bind,src=${HOST_CLAUDE_DIR},dst=${HOST_HOME}/.claude"
  --mount "type=bind,src=${HOST_CODEX_DIR},dst=${HOST_HOME}/.codex"
  --mount "type=bind,src=${HOST_COPILOT_DIR},dst=${HOST_HOME}/.copilot"
  --mount "type=bind,src=${HOST_GEMINI_DIR},dst=${HOST_HOME}/.gemini"
  --mount "type=bind,src=${HOST_VIBE_DIR},dst=${HOST_HOME}/.vibe"
  --mount "type=bind,src=${HOST_M2_DIR},dst=${HOST_HOME}/.m2"
  --mount "type=bind,src=${HOST_VAADIN_DIR},dst=${HOST_HOME}/.vaadin"
  --mount "type=bind,src=${main_host},dst=${main_host}"
)

add_shared_skills_mount() {
  local dst="$1"
  local dst_parent="$2"

  [[ -n "$dst_parent" ]] && mkdir -p "$dst_parent"
  container_argv+=( --mount "type=bind,src=${share_skills_dir},dst=${dst}" )
  echo "Sharing skills: ${share_skills_dir} -> ${dst}" >&2
}

if [[ -n "$share_skills_dir" ]]; then
  add_shared_skills_mount "${HOST_CLAUDE_DIR}/skills" "${HOST_CLAUDE_DIR}"
  add_shared_skills_mount "${HOST_CODEX_DIR}/skills" "${HOST_CODEX_DIR}"
  add_shared_skills_mount "${HOST_HOME}/.agents/skills" "${HOST_HOME}/.agents"
  add_shared_skills_mount "${HOST_COPILOT_DIR}/skills" "${HOST_COPILOT_DIR}"
  add_shared_skills_mount "${HOST_GEMINI_DIR}/skills" "${HOST_GEMINI_DIR}"
  add_shared_skills_mount "${HOST_VIBE_DIR}/skills" "${HOST_VIBE_DIR}"

  if [[ -d "${HOST_CODEX_DIR}/skills/.system" ]]; then
    container_argv+=( --mount "type=bind,src=${HOST_CODEX_DIR}/skills/.system,dst=${HOST_CODEX_DIR}/skills/.system" )
    echo "Sharing Codex system skills: ${HOST_CODEX_DIR}/skills/.system -> ${HOST_CODEX_DIR}/skills/.system" >&2
  fi
fi

# Mount worktree's main repository .git directory (not the working tree)
if [[ -n "$worktree_main_repo" ]]; then
  container_argv+=( --mount "type=bind,src=${worktree_main_repo}/.git,dst=${worktree_main_repo}/.git" )
fi

# Protect .git/config from AI tools changing remote URLs
git_protect_dirs="${main_host}"
for p in "${paths[@]:1}"; do
  git_protect_dirs="${git_protect_dirs}:$(resolve_path "$p")"
done
if [[ -n "$worktree_main_repo" ]]; then
  git_protect_dirs="${git_protect_dirs}:${worktree_main_repo}"
fi
container_argv+=( -e "GIT_PROTECT_DIRS=${git_protect_dirs}" )

# Add port mappings
for pm in "${port_maps[@]+"${port_maps[@]}"}"; do
  container_argv+=( -p "$pm" )
done

# Add host port forwards (container localhost → host)
if [[ ${#host_forwards[@]} -gt 0 ]]; then
  IFS=','; forwards_str="${host_forwards[*]}"; unset IFS
  container_argv+=( -e "HOST_FORWARD_PORTS=${forwards_str}" )
fi

# SSH agent forwarding (opt-in for security)
if [[ $ssh_mode -eq 1 ]]; then
  # macOS Docker Desktop: use the special bridged socket
  # Linux: mount the actual socket
  if [[ "$(uname)" == "Darwin" ]]; then
    container_argv+=(
      --mount "type=bind,src=/run/host-services/ssh-auth.sock,dst=/ssh-agent"
      -e "SSH_AUTH_SOCK=/ssh-agent"
    )
  elif [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
    container_argv+=(
      -v "${SSH_AUTH_SOCK}:/ssh-agent"
      -e "SSH_AUTH_SOCK=/ssh-agent"
    )
  fi
fi

# On Linux, add host.docker.internal mapping (macOS/Windows have it built-in)
if [[ "$(uname)" == "Linux" ]]; then
  container_argv+=( --add-host "host.docker.internal:host-gateway" )
fi

# Share ~/.claude.json via symlink to shared directory (can't bind-mount individual files)
# See: https://github.com/apple/containerization/issues/79
# Canonical location is ~/.claude-contained/.claude.json; ~/.claude.json is a symlink to it.
# All containers access the same file via virtiofs, so Claude Code's own locking works.
HOST_CLAUDE_CONTAINED="${HOST_HOME}/.claude-contained"
HOST_CLAUDE_JSON="${HOST_HOME}/.claude.json"
SHARED_CLAUDE_JSON="${HOST_CLAUDE_CONTAINED}/.claude.json"
mkdir -p "${HOST_CLAUDE_CONTAINED}"

# Git config (for commit identity)
# Copy to shared directory for consistency with claude-contained (entrypoint copies to ~/.gitconfig)
if [[ -f "${HOST_GITCONFIG}" ]]; then
  cp "${HOST_GITCONFIG}" "${HOST_CLAUDE_CONTAINED}/.gitconfig"
fi

# Migrate/repair: ensure ~/.claude.json is symlink to shared location
if [[ -f "$HOST_CLAUDE_JSON" && ! -L "$HOST_CLAUDE_JSON" ]]; then
  # Host file is regular file (not symlink) - migrate it to shared location
  # This handles: first run, or host Claude Code replaced symlink via atomic write
  mv "$HOST_CLAUDE_JSON" "$SHARED_CLAUDE_JSON"
  ln -s "$SHARED_CLAUDE_JSON" "$HOST_CLAUDE_JSON"
elif [[ -L "$HOST_CLAUDE_JSON" && ! -e "$SHARED_CLAUDE_JSON" ]]; then
  # Symlink exists but target doesn't - broken symlink, remove it
  rm "$HOST_CLAUDE_JSON"
fi

# Ensure symlink exists (if shared file exists but no symlink yet)
if [[ ! -e "$HOST_CLAUDE_JSON" && -f "$SHARED_CLAUDE_JSON" ]]; then
  ln -s "$SHARED_CLAUDE_JSON" "$HOST_CLAUDE_JSON"
fi

# Mount the shared directory for bidirectional ~/.claude.json access
container_argv+=( --mount "type=bind,src=${HOST_CLAUDE_CONTAINED},dst=${HOST_CLAUDE_CONTAINED}" )

# Build tool-specific command
case "$tool" in
  claude)
    tool_argv=(claude)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--dangerously-skip-permissions)
    ;;
  codex)
    tool_argv=(codex)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--yolo)
    ;;
  copilot)
    tool_argv=(copilot)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--yolo)
    ;;
  gemini)
    tool_argv=(gemini)
    [[ $yolo_mode -eq 1 ]] && tool_argv+=(--yolo)
    ;;
  vibe)
    tool_argv=(vibe)
    [[ $yolo_mode -eq 1 ]] && echo "Warning: vibe does not support yolo mode (no equivalent flag)" >&2
    ;;
  *)
    echo "Unknown tool: $tool" >&2
    echo "Supported tools: claude, codex, copilot, gemini, vibe" >&2
    exit 1
    ;;
esac

# Additional mounts at original host paths
for i in "${!paths[@]}"; do
  [[ $i -eq 0 ]] && continue
  hp="$(resolve_path "${paths[$i]}")"
  mopts="type=bind,src=${hp},dst=${hp}"
  [[ "${path_modes[$i]}" == "ro" ]] && mopts="${mopts},readonly"
  container_argv+=( --mount "$mopts" )
  # Only claude and codex support --add-dir
  [[ "$tool" == "claude" || "$tool" == "codex" ]] && tool_argv+=( --add-dir "${hp}" )
done

# Platform-specific node_modules overlay
if [[ "$(uname)" != "Linux" ]]; then
  # Container is Linux; host is not — node_modules may need platform-specific binaries
  nm_platform="linux-$(container_arch)"
  nm_check_dirs=("$main_host")
  # Skip read-only extras: the overlay needs to write .claude-contained/ inside the dir.
  for i in "${!paths[@]}"; do
    [[ $i -eq 0 ]] && continue
    [[ "${path_modes[$i]}" == "ro" ]] && continue
    nm_check_dirs+=("$(resolve_path "${paths[$i]}")")
  done

  nm_overlay_dirs=()
  for nm_dir in "${nm_check_dirs[@]}"; do
    [[ -f "${nm_dir}/package.json" ]] && nm_overlay_dirs+=("$nm_dir")
  done

  if [[ ${#nm_overlay_dirs[@]} -gt 0 ]]; then
    do_overlay=$contained_node_modules
    if [[ $do_overlay -eq 0 ]]; then
      read -p "Node.js project detected. Use container-specific node_modules? [Y/n] " answer
      [[ "${answer:-Y}" =~ ^[Yy] ]] && do_overlay=1
    fi

    if [[ $do_overlay -eq 1 ]]; then
      for nm_dir in "${nm_overlay_dirs[@]}"; do
        nm_target="${nm_dir}/.claude-contained/node_modules-${nm_platform}"
        mkdir -p "${nm_target}"
        container_argv+=( --mount "type=bind,src=${nm_target},dst=${nm_dir}/node_modules" )
        if dir_is_empty "${nm_target}"; then
          echo "Created ${nm_target}" >&2
          echo "  Run 'npm install' (or your package manager) inside the container." >&2
        fi
      done
    fi
  fi
fi

# Note: worktree main repo is NOT added via --add-dir since only .git is mounted (no working tree)

# Append user's tool args
if [[ ${#tool_args[@]} -gt 0 ]]; then
  tool_argv+=( "${tool_args[@]}" )
fi

# Run container
if [[ $shell_mode -eq 1 ]]; then
  "${container_argv[@]}" claude-contained:latest bash && container_exit=0 || container_exit=$?
else
  "${container_argv[@]}" claude-contained:latest "${tool_argv[@]}" && container_exit=0 || container_exit=$?
fi

check_for_updates

exit "$container_exit"
